views:
  - type: table
    name: 表格
    order:
      - file.name
      - file.basename
      - file.folder
      - file.backlinks
    sort:
      - property: file.folder
        direction: ASC
  - type: table
    name: 视图
    order:
      - file.name
      - file.basename
      - file.folder
      - file.links
    sort:
      - property: file.folder
        direction: ASC
