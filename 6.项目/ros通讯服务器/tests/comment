# 1. 回到项目根目录，清理旧的构建垃圾
rm -rf build/ install/ log/

# 2. 加载 ROS 环境
source /opt/ros/humble/setup.bash

# 3. 生成构建配置 (关键：生成 compile_commands.json)
cmake -S . -B build -G Ninja -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DCMAKE_C_COMPILER=/usr/bin/clang -DCMAKE_CXX_COMPILER=/usr/bin/clang++

# 4. 开始编译
cmake --build build

# 5. 刷新环境
source install/setup.bash

# 6. 运行节点
ros2 run mfms_server mfms_server