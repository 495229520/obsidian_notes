int32 id # 指令ID
bool en # 是否使能

bool joint_or_desc # 0-关节坐标,1-笛卡尔坐标
# 关节坐标运动:对应关节的6个轴;笛卡尔坐标:0-2对应tran坐标的xyz,3-5对应rpy位姿的rx,ry,rz
float64[6] position

# 关节轴运动
uint8 axid # 关节的轴，运动的关节轴对应1-6
uint8 dir # 运动的方向，0-负时针,1-顺时针
float64 deg # 单位:度

int32 speed # 全局设置速度
float64 acc # 全局设置加速度
int32 tool # 以后的工具设置

int32 mode # 机器人操作模式

int32 register_index # 系统变量编号
float64 register_value # 系统变量的值

bool input_or_output # 0-DI口,1-DO口
int32 io_index # io口的编号 0-15
bool io_value # io口的状态

string program # 加载的程序名称

int32 interval # 记录的间隔，多少毫秒记一次
string filename # csv文件名

JointPoint[] joint_path # 关节位置

int32 gripper_index # 夹爪编号
uint8 act # 0-复位，1-激活
int32 gripper_pos # 位置百分比，范围[0~100]
int32 gripper_vel # 速度百分比，范围[0~100]
int32 gripper_force # 力矩百分比，范围[0~100]
int32 max_time # 最大等待时间，范围[0~30000]，单位ms
uint8 gripper_block # 0-阻塞，1-非阻塞

---
int32 err_code # 错误码
FrRobotState pub_state # 机器人的状态数据
float64 register_val    #机器人寄存器值-只读 与register_index同时用
bool io_val #机器人IO口值，与input_or_output和io_index同时使用
float64[6] jt_pos # 关节位置
float64[6] tl_pos # 笛卡尔位置
